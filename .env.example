# --- Hadoop Configuration ---
# Đường dẫn cài đặt Hadoop thực tế trên hệ thống (ví dụ: /usr/local/hadoop)
HADOOP_HOME=C:\hadoop-3.3.0

# Địa chỉ HDFS NameNode (thường là hdfs://localhost:9000)
HDFS_HOST=hdfs://localhost:9000

# Đường dẫn đến file thực thi Hive
HIVE_BIN=C:\hive\bin\hive

# --- Application Configuration ---
# URL của Flask Backend (Member 3) để thực hiện dự đoán chi phí
FLASK_API_URL=http://localhost:5000

# Số lượng bệnh muốn ưu tiên hiển thị trên biểu đồ
TOP_N_DISEASES=10

# --- Java Configuration ---
# Một số hệ thống yêu cầu JAVA_HOME chính xác cho Hadoop
# JAVA_HOME=C:\Program Files\Java\jdk1.8.0_202
